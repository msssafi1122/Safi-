<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutChatRoot"
    android:layout_width="320dp"
    android:layout_height="400dp"
    android:background="@drawable/bg_glassmorphism"
    android:orientation="vertical"
    android:padding="8dp"
    android:elevation="12dp">

    <!-- Header bar -->
    <RelativeLayout
        android:id="@+id/chatHeader"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#15FFFFFF"
        android:padding="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SAFI AI (Groq)"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnChatClear"
                android:layout_width="36dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#88FFFFFF"
                android:contentDescription="Clear Conversation" />

            <ImageButton
                android:id="@+id/btnChatClose"
                android:layout_width="36dp"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#FF3366"
                android:contentDescription="Close Chat Window" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChatHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="4dp"
        android:scrollbars="vertical" />

    <!-- Typing feedback indicator -->
    <TextView
        android:id="@+id/tvChatTypingIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI is typing..."
        android:textColor="#03DAC6"
        android:textSize="11sp"
        android:textStyle="italic"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone" />

    <!-- Message Compose Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <EditText
            android:id="@+id/etChatMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ask anything..."
            android:textColorHint="#60FFFFFF"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:background="#20FFFFFF"
            android:padding="10dp"
            android:layout_marginEnd="6dp"
            android:inputType="textLongMessage|textAutoCorrect" />

        <ImageButton
            android:id="@+id/btnChatSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_bubble"
            android:src="@android:drawable/ic_menu_send"
            android:tint="#FFFFFF"
            android:contentDescription="Submit prompt" />
    </LinearLayout>

</LinearLayout>
