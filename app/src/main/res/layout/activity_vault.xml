<?xml version="1.0" encoding="utf-8"?>
<ViewAnimator xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/vaultViewAnimator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Screen 0: Fake Calculator Unlock Gate -->
    <LinearLayout
        android:id="@+id/layoutCalculatorGate"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="bottom">

        <!-- Calculator Screen -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="bottom|end"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvGateInstructions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scientific Vault Calculator\nEnter PIN and press ="
                android:textColor="#55FFFFFF"
                android:textSize="12sp"
                android:layout_gravity="start"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvGateExpression"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#88FFFFFF"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/tvGateDisplay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="48sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Calculator Keyboard Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnGateClear"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="AC"
                android:textColor="#FF3366"
                android:textSize="18sp"
                android:textStyle="bold" />
            <Button
                android:id="@+id/btnGateParenOpen"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="("
                android:textColor="#03DAC6"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGateParenClose"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text=")"
                android:textColor="#03DAC6"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGateDiv"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="/"
                android:textColor="#03DAC6"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Calculator Keyboard Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnGate7"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="7"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGate8"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="8"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGate9"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="9"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGateMul"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="x"
                android:textColor="#03DAC6"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Calculator Keyboard Row 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnGate4"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="4"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGate5"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="5"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGate6"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="6"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGateSub"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="-"
                android:textColor="#03DAC6"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Calculator Keyboard Row 4 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnGate1"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="1"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGate2"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="2"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGate3"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGateAdd"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="+"
                android:textColor="#03DAC6"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Calculator Keyboard Row 5 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGateDot"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="."
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGate0"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGatePercent"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="%"
                android:textColor="#FFFFFF"
                android:textSize="18sp" />
            <Button
                android:id="@+id/btnGateEquals"
                android:layout_width="0dp"
                android:layout_height="70dp"
                android:layout_weight="1"
                android:text="="
                android:textColor="#121212"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="#03DAC6"
                app:cornerRadius="15dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Screen 1: Unlocked Private Hidden Vault Panel -->
    <LinearLayout
        android:id="@+id/layoutVaultContents"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Secure SAFI Vault"
                android:textColor="#FF3366"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true" />

            <Button
                android:id="@+id/btnExitVault"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOCK"
                android:textColor="#FF5555"
                android:textStyle="bold"
                android:layout_alignParentEnd="true" />
        </RelativeLayout>

        <!-- Vault Subtitle and Control Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Hidden Private Gallery"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnImportMedia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+ HIDE PHOTO"
                android:textColor="#121212"
                android:textStyle="bold"
                android:textSize="12sp"
                app:backgroundTint="#03DAC6"
                app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- No photos layout -->
        <TextView
            android:id="@+id/tvNoMedia"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:text="Your vault is empty.\nClick + HIDE PHOTO to encrypt and store images securely in private database sandbox."
            android:textColor="#55FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="visible" />

        <!-- Security gallery Grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvVaultGallery"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />

    </LinearLayout>
</ViewAnimator>
