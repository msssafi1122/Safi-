<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/layoutCalcRoot"
    android:layout_width="320dp"
    android:layout_height="440dp"
    android:background="@drawable/bg_glassmorphism"
    android:orientation="vertical"
    android:padding="8dp"
    android:elevation="12dp">

    <!-- Header bar -->
    <RelativeLayout
        android:id="@+id/calcHeader"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#15FFFFFF"
        android:padding="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scientific Math Grid"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/btnCalcClose"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FF3366"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="Close Calculator Window" />
    </RelativeLayout>

    <!-- Display Outputs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:paddingEnd="12dp"
        android:paddingStart="12dp"
        android:layout_marginBottom="6dp"
        android:background="#0FFFFFFF">

        <TextView
            android:id="@+id/tvCalcExpression"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:singleLine="true" />

        <TextView
            android:id="@+id/tvCalcDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold"
            android:singleLine="true" />
    </LinearLayout>

    <!-- Scientific Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button android:id="@+id/btnSin" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="sin" android:textColor="#03DAC6" android:textSize="12sp" android:padding="0dp" />
        <Button android:id="@+id/btnCos" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="cos" android:textColor="#03DAC6" android:textSize="12sp" android:padding="0dp" />
        <Button android:id="@+id/btnTan" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="tan" android:textColor="#03DAC6" android:textSize="12sp" android:padding="0dp" />
        <Button android:id="@+id/btnLog" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="log" android:textColor="#03DAC6" android:textSize="12sp" android:padding="0dp" />
        <Button android:id="@+id/btnLn"  style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="ln"  android:textColor="#03DAC6" android:textSize="12sp" android:padding="0dp" />
    </LinearLayout>

    <!-- Scientific Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <Button android:id="@+id/btnPower" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="^"   android:textColor="#03DAC6" android:textSize="14dp" />
        <Button android:id="@+id/btnSqrt"  style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="√"   android:textColor="#03DAC6" android:textSize="14dp" />
        <Button android:id="@+id/btnParenO" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="("   android:textColor="#03DAC6" android:textSize="14dp" />
        <Button android:id="@+id/btnParenC" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text=")"   android:textColor="#03DAC6" android:textSize="14dp" />
        <Button android:id="@+id/btnCalcClear" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="AC" android:textColor="#FF3366" android:textSize="14dp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Number Pad Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="horizontal">

        <Button android:id="@+id/btnCalc7" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="7" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalc8" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="8" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalc9" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="9" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalcDiv" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="/" android:textColor="#7C4DFF" android:textSize="16dp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Number Pad Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="horizontal">

        <Button android:id="@+id/btnCalc4" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="4" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalc5" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="5" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalc6" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="6" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalcMul" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="x" android:textColor="#7C4DFF" android:textSize="16dp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Number Pad Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="horizontal">

        <Button android:id="@+id/btnCalc1" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalc2" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="2" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalc3" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="3" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalcSub" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="-" android:textColor="#7C4DFF" android:textSize="16dp" android:textStyle="bold" />
    </LinearLayout>

    <!-- Number Pad Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.2"
        android:orientation="horizontal">

        <Button android:id="@+id/btnCalcDot" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="." android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalc0" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="0" android:textColor="#FFFFFF" android:textSize="16dp" />
        <Button android:id="@+id/btnCalcAdd" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="+" android:textColor="#7C4DFF" android:textSize="16dp" android:textStyle="bold" />
        <Button android:id="@+id/btnCalcEquals" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.1" android:text="=" android:textColor="#121212" android:textSize="18dp" android:textStyle="bold" app:backgroundTint="#03DAC6" app:cornerRadius="10dp" />
    </LinearLayout>
</LinearLayout>
