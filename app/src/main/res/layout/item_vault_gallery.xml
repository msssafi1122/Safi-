<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="120dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#1A1A1A"
    app:strokeColor="#10FFFFFF"
    app:strokeWidth="1dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/ivVaultThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Private Hidden Asset" />

        <!-- Simple visual overlay to click for item operations / deletion -->
        <ImageButton
            android:id="@+id/ibDeleteVaultItem"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:layout_margin="6dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="#FF3366"
            android:contentDescription="Delete Hidden File" />

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
